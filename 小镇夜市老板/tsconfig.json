{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "assets/scripts/*"
      ]
    }
  },
  "include": [
    "assets/scripts/**/*.ts"
  ],
  "exclude": [
    "build",
    "library",
    "local",
    "temp"
  ]
}
